APP_NAME=Car Vision Agent System
APP_ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=120
OPENAPI_DESCRIPTION=智能车载视觉感知与交互系统后端 API
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json
API_CONTACT_NAME=Car Vision Team
API_CONTACT_EMAIL=team@example.com
DATA_ENCRYPTION_KEY=
DATA_HASH_KEY=
DATABASE_URL=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=bank
MYSQL_PASSWORD=replace-with-your-password
MYSQL_DATABASE=car_vision_agent_system
MYSQL_CHARSET=utf8mb4
REDIS_URL=redis://localhost:6379/0
LLM_PROVIDER=openai-compatible
LLM_API_BASE=https://api.example.com/v1
LLM_API_KEY=replace-with-your-key
LLM_REQUEST_TIMEOUT_SECONDS=10
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=example@163.com
SMTP_PASSWORD=replace-with-your-smtp-password
SMTP_SENDER_NAME=Car Vision System
SMTP_USE_SSL=true
EMAIL_CODE_EXPIRE_MINUTES=5
EMAIL_CODE_COOLDOWN_SECONDS=60
ALERT_EMAIL_RECIPIENTS=[]
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=8
ALLOWED_ORIGINS=["http://localhost:5173"]
ALERT_CONSECUTIVE_FAILURES_THRESHOLD=3
ALERT_LOW_CONFIDENCE_THRESHOLD=0.6
ALERT_LOW_CONFIDENCE_WINDOW_SIZE=3
ALERT_REPLAY_WINDOW_MINUTES=20
HYPERLPR_DETECT_LEVEL=high
HYPERLPR_HOME_DIR=runtime
PLATE_CONFIDENCE_THRESHOLD=0.5
PLATE_INFERENCE_TIMEOUT_SECONDS=10
PLATE_HISTORY_LIMIT=50
PLATE_SAVE_UPLOADS=false
PLATE_UPLOAD_DIR=uploads/plate

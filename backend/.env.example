APP_NAME=Car Vision Agent System
APP_ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=sqlite:///./car_vision.db
REDIS_URL=redis://localhost:6379/0
LLM_PROVIDER=openai-compatible
LLM_API_BASE=https://api.example.com/v1
LLM_API_KEY=replace-with-your-key
ALLOWED_ORIGINS=["http://localhost:5173"]
HYPERLPR_DETECT_LEVEL=high
HYPERLPR_HOME_DIR=runtime
PLATE_MAX_IMAGE_SIDE=1600
PLATE_CONFIDENCE_THRESHOLD=0.35
PLATE_STREAM_RECOGNITION_MAX_SIDE=0
PLATE_STREAM_MAX_SIDE=960
PLATE_STREAM_MAX_FPS=8
PLATE_STREAM_PROCESS_EVERY_N_FRAMES=8
PLATE_STREAM_JPEG_QUALITY=80
PLATE_STREAM_DETECTION_HOLD_SECONDS=0.8
PLATE_STREAM_TRACKING_MAX_MISSES=6
PLATE_STREAM_TRACKING_MATCH_THRESHOLD=0.45
PLATE_STREAM_TRACKING_SEARCH_EXPAND=2.4
PLATE_STREAM_TRACKING_TEMPLATE_UPDATE_ALPHA=0.18
PLATE_STREAM_HISTORY_INTERVAL_SECONDS=3
PLATE_HISTORY_LIMIT=50
PLATE_SAVE_UPLOADS=false
PLATE_UPLOAD_DIR=uploads/plate

APP_NAME=Car Vision Agent System
APP_ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=sqlite:///./car_vision.db
REDIS_URL=redis://localhost:6379/0
LLM_PROVIDER=openai-compatible
LLM_API_BASE=https://api.example.com/v1
LLM_API_KEY=replace-with-your-key
ALLOWED_ORIGINS=["http://localhost:5173"]
HYPERLPR_DETECT_LEVEL=high
HYPERLPR_HOME_DIR=runtime
PLATE_DETECTOR_ENABLED=true
PLATE_DETECTOR_FALLBACK_TO_FULL_FRAME=true
PLATE_DETECTOR_CROP_PADDING_X=0.16
PLATE_DETECTOR_CROP_PADDING_Y=0.30
PLATE_DETECTOR_MAX_CANDIDATES=12
PLATE_DETECTOR_CLASS_NAMES=["plate","license-plate","licence-plate","lp"]
PLATE_VEHICLE_DETECTOR_FALLBACK_ENABLED=false
PLATE_VEHICLE_CLASS_NAMES=["car","truck","bus"]
PLATE_VEHICLE_CROP_PADDING_X=0.08
PLATE_VEHICLE_CROP_PADDING_Y=0.05
PLATE_VEHICLE_PLATE_TOP_RATIO=0.52
PLATE_VEHICLE_PLATE_HEIGHT_RATIO=0.24
PLATE_VEHICLE_PLATE_WIDTH_RATIO=0.60
PLATE_YOLO_MODEL_PATH=weights/open_traffic_flow_best.pt
PLATE_YOLO_CONFIDENCE=0.18
PLATE_YOLO_IMGSZ=960
PLATE_YOLO_MAX_DET=20
PLATE_YOLO_DEVICE=cpu
PLATE_MAX_IMAGE_SIDE=1600
PLATE_CONFIDENCE_THRESHOLD=0.35
PLATE_STREAM_RECOGNITION_MAX_SIDE=0
PLATE_STREAM_MAX_SIDE=960
PLATE_STREAM_MAX_FPS=8
PLATE_STREAM_PROCESS_EVERY_N_FRAMES=8
PLATE_STREAM_JPEG_QUALITY=80
PLATE_STREAM_DETECTION_HOLD_SECONDS=0.8
PLATE_STREAM_TRACKING_MAX_MISSES=6
PLATE_STREAM_TRACKING_MATCH_THRESHOLD=0.45
PLATE_STREAM_TRACKING_SEARCH_EXPAND=2.4
PLATE_STREAM_TRACKING_TEMPLATE_UPDATE_ALPHA=0.18
PLATE_STREAM_HISTORY_INTERVAL_SECONDS=3
PLATE_HISTORY_LIMIT=50
PLATE_VIDEO_PROCESS_EVERY_N_FRAMES=14
PLATE_VIDEO_RECOGNITION_MAX_SIDE=896
PLATE_VIDEO_DETECTOR_FULL_FRAME_FALLBACK=false
PLATE_OPEN_TRAFFIC_FLOW_LPR_ENABLED=true
PLATE_OPEN_TRAFFIC_FLOW_LPR_MODEL_PATH=weights/Final_LPRNet_model.pth
PLATE_OPEN_TRAFFIC_FLOW_LPR_DEVICE=cpu
PLATE_OPEN_TRAFFIC_FLOW_LPR_CONFIDENCE_THRESHOLD=0.55
PLATE_SAVE_UPLOADS=false
PLATE_UPLOAD_DIR=uploads/plate
PLATE_PUSH_FFMPEG_BIN=C:\Tools\ffmpeg\ffmpeg-master-latest-win64-gpl-shared\bin\ffmpeg.exe
PLATE_PUSH_STREAM_NAME=plate-live
PLATE_PUSH_RTSP_BASE_URL=rtsp://127.0.0.1:8554
PLATE_PUSH_PLAYBACK_BASE_URL=http://127.0.0.1:8889
PLATE_PUSH_FPS=25
PLATE_PUSH_BITRATE=2M
